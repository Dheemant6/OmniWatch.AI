# === OmniWatch AI Backend Configuration ===

# Application
PROJECT_NAME="OmniWatch.AI_Backend"
API_V1_STR="/api/v1"
BACKEND_CORS_ORIGINS=["*"]

# Database
# For SQLite use: sqlite:///./app.db
# For PostgreSQL use: postgresql+asyncpg://user:password@localhost/dbname
DATABASE_URI="sqlite+aiosqlite:///./app.db"

# Security
# Run `openssl rand -hex 32` to generate a secure secret key
SECRET_KEY="YOUR_SUPER_SECRET_KEY_HERE"
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 hours

# Third-party Integrations
GITHUB_TOKEN=""
# AI Semantic Engine
HF_TOKEN="" # HuggingFace token if using gated models
OPENAI_API_KEY="sk-dummy" # Ollama doesn't require a real local key
OPENAI_API_BASE="http://localhost:11434/v1" # Point to the local Ollama Server
